# PropelERP Environment Configuration
NODE_ENV=production
APP_NAME=PropelERP

# URLs
APP_URL=https://propelerp.wisewit.ai
API_URL=https://propelerp.wisewit.ai

# Database - Docker internal networking
DATABASE_URL=postgresql://propel_user:propel_pass@postgres:5432/propel_erp
DB_HOST=postgres
DB_PORT=5432
DB_NAME=propel_erp
DB_USER=propel_user
DB_PASSWORD=propel_pass

# Redis
REDIS_URL=redis://redis:6379

# MongoDB
MONGODB_URI=mongodb://mongodb:27017/propel_docs

# Auth
JWT_SECRET=propelerp_jwt_secret_change_in_production_2026
JWT_EXPIRES_IN=7d

# AI Engine (Emergent LLM)
EMERGENT_LLM_KEY=sk-emergent-fEaE0F189Bb1a11AdD

# Feature Flags
ENABLE_AI_MODULE=true
ENABLE_SMS=false
ENABLE_EMAIL=false
