# ============================================================
# PropelERP — Production Environment Variables
# For deployment to propelerp.wisewit.ai on OCI VM
# ============================================================

# --- App ---
NODE_ENV=production
APP_NAME=PropelERP
APP_URL=https://propelerp.wisewit.ai
API_URL=https://propelerp.wisewit.ai
AI_ENGINE_URL=http://ai-engine:8000

# --- Database (PostgreSQL) - UPDATE PASSWORD! ---
DATABASE_URL=postgresql://propel_user:CHANGE_THIS_SECURE_PASSWORD@postgres:5432/propel_erp
DB_HOST=postgres
DB_PORT=5432
DB_NAME=propel_erp
DB_USER=propel_user
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MongoDB (Document Storage) ---
MONGODB_URI=mongodb://mongodb:27017/propel_docs

# --- Auth - UPDATE SECRETS! ---
NEXTAUTH_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
NEXTAUTH_URL=https://propelerp.wisewit.ai
JWT_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_STRING_32_CHARS
JWT_EXPIRES_IN=7d

# --- AWS S3 (File Storage) - OPTIONAL ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=propel-erp-documents

# --- Email (Brevo/SendGrid) - MOCKED FOR NOW ---
BREVO_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=noreply@wisewit.ai
EMAIL_FROM_NAME=PropelERP

# --- SMS (Brevo) - MOCKED FOR NOW ---
SMS_SENDER_NAME=PROPEL

# --- AI Engine (Emergent LLM) ---
EMERGENT_LLM_KEY=sk-emergent-fEaE0F189Bb1a11AdD

# --- Feature Flags ---
ENABLE_AI_MODULE=true
ENABLE_SMS=false
ENABLE_EMAIL=false
ENABLE_MOBILE_API=true

# --- Pagination ---
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
