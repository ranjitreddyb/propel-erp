# Simple development Dockerfile for Node.js backend
FROM node:20-alpine
WORKDIR /app

# Install dependencies
COPY package.json ./
RUN npm install

# Copy source
COPY . .

# Expose port
EXPOSE 4000

# Health check
HEALTHCHECK --interval=30s --timeout=5s \
  CMD wget -qO- http://localhost:4000/health || exit 1

# Run in dev mode
CMD ["npm", "run", "dev"]
