# Simple development Dockerfile for Next.js
FROM node:20-alpine
WORKDIR /app

# Install dependencies
COPY package.json ./
RUN npm install

# Copy source
COPY . .

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=5s \
  CMD wget -qO- http://localhost:3000 || exit 1

# Run in dev mode
CMD ["npm", "run", "dev"]
