# ============================================================
# PropelERP — Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# --- App ---
NODE_ENV=development
APP_NAME=PropelERP
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_ENGINE_URL=http://localhost:8000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://propel_user:propel_pass@localhost:5432/propel_erp
DB_HOST=localhost
DB_PORT=5432
DB_NAME=propel_erp
DB_USER=propel_user
DB_PASSWORD=propel_pass

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- MongoDB (Document Storage) ---
MONGODB_URI=mongodb://localhost:27017/propel_docs

# --- Auth ---
NEXTAUTH_SECRET=your-super-secret-nextauth-key-min-32-chars
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# --- AWS S3 (File Storage) ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=propel-erp-documents

# --- Email (SendGrid) ---
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@wisewit.ai
EMAIL_FROM_NAME=PropelERP

# --- SMS (MSG91 - India) ---
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=PROPEL
MSG91_TEMPLATE_ID=your-template-id

# --- AI Engine ---
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Multi-tenancy ---
DEFAULT_COMPANY_ID=1
MAX_COMPANIES_PER_ACCOUNT=10

# --- Pagination ---
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# --- Feature Flags ---
ENABLE_AI_MODULE=true
ENABLE_SMS=true
ENABLE_EMAIL=true
ENABLE_MOBILE_API=true
