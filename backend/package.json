{
  "name": "propel-erp-backend",
  "version": "1.0.0",
  "description": "PropelERP Backend API — Node.js + Express + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "node -r ts-node/register src/utils/migrate.ts",
    "db:seed": "node -r ts-node/register database/seeds/seed.ts",
    "test": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.1",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "mongoose": "^8.1.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4",
    "nodemailer": "^6.9.8",
    "multer": "^1.4.5-lts.1",
    "@aws-sdk/client-s3": "^3.490.0",
    "uuid": "^9.0.0",
    "dayjs": "^1.11.10",
    "lodash": "^4.17.21",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "express-async-errors": "^3.1.1",
    "bull": "^4.12.2",
    "axios": "^1.6.5",
    "socket.io": "^4.6.2",
    "pdfkit": "^0.14.0",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/lodash": "^4.14.202",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0"
  }
}
